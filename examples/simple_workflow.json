{
  "name": "Simple File Operations",
  "description": "A simple workflow demonstrating file operations",
  "version": "1.0.0",
  "variables": [
    {
      "name": "output_dir",
      "value": "./output",
      "type": "string"
    }
  ],
  "steps": [
    {
      "id": "step1",
      "name": "Create output directory",
      "type": "file",
      "enabled": true,
      "parallel": false,
      "parameters": {
        "action": "mkdir",
        "path": "${output_dir}",
        "recursive": true
      }
    },
    {
      "id": "step2",
      "name": "Write test file",
      "type": "file",
      "enabled": true,
      "parallel": false,
      "parameters": {
        "action": "write",
        "path": "${output_dir}/test.txt",
        "content": "Hello from Auto Workflow!"
      }
    },
    {
      "id": "step3",
      "name": "Read test file",
      "type": "file",
      "enabled": true,
      "parallel": false,
      "parameters": {
        "action": "read",
        "path": "${output_dir}/test.txt"
      }
    },
    {
      "id": "step4",
      "name": "Log success message",
      "type": "control",
      "enabled": true,
      "parallel": false,
      "parameters": {
        "action": "log",
        "message": "File operations completed successfully!",
        "level": "info"
      }
    }
  ],
  "on_error": {
    "action": "stop",
    "notify": true
  }
}
